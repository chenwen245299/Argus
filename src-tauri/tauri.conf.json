{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Argus",
  "version": "0.1.0",
  "identifier": "com.argus.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Argus",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "maximizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE0MjQzNTczMDE5RTQ2OTAKUldTUVJwNEJjelVrRkEzRmFmNER4NmFPVFB3c1l0MUdadThMSUIxNmpIREhsdDBITVVMTEtWZjgK",
      "endpoints": [
        "https://github.com/chenwen245299/Argus/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": false,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
